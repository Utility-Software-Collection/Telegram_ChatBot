# 服务器端口
PORT=3000

# 数据库类型 (kv / d1 / hyperdrive)
ACTIVE_DB=kv

# KV 文件路径（SQLite 存储文件）
KV_FILE=db.sqlite

# PostgreSQL 连接字符串（Hyperdrive 模式）
DATABASE_URL=

# Cookie Secure 标志（HTTPS 反向代理时设为 true）
COOKIE_SECURE=false

# KV 持久化
KV_PERSIST=true

# 初始管理员账号（Docker/VPS 部署，可选）
# 设置后使用此密码创建初始管理员，密码不会以明文出现在日志中
# 未设置时会自动生成临时密码，并在首次启动日志中明文打印一次
# ADMIN_USERNAME=admin
# ≥10 位，须含字母与数字，不能是常见弱口令
# ADMIN_PASSWORD=ChangeMe123!

# 跨域管理后台白名单（可选，多个逗号分隔）。未配置时默认同源，不返回 *
# CORS_ORIGIN=https://admin.example.com

# 迁移期兼容：允许旧版 salt:sha256 密码哈希登录（登录后会自动 rehash 为 PBKDF2）
# 默认关闭；仅在升级旧库时临时开启
# ALLOW_LEGACY_PASSWORD_HASH=1

# 迁移期兼容：吊销会话时额外全表扫描 sess:（默认仅用 sess_user: 索引 + epoch）
# SESSION_LEGACY_SCAN=1

# 管理员恢复 CLI 默认读取以下路径（可用 npm run admin -- list）
# KV_FILE=./data/kv-store.db
# D1_FILE=./data/d1-store.db
# DATABASE_URL=
